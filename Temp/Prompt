## Key data logic (categoryHelpers.ts)

```ts
// Build tree from flat array
function flatToTree(cats: Category[]): TreeNode[] {
  const map = new Map(cats.map(c => [c.id, { ...c, children: [] }]))
  const roots: TreeNode[] = []
  for (const node of map.values()) {
    node.parent_id ? map.get(node.parent_id)?.children.push(node) : roots.push(node)
  }
  return roots.sort((a, b) => a.sort_order - b.sort_order)
}

// Auto-generate slug
function computeSlug(nameEn: string, parentSlug?: string): string {
  const base = nameEn.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')
  return parentSlug ? `${parentSlug}/${base}` : base
}

// Level is always parent.level + 1 (0 = root)
function computeLevel(parentId: string | null, cats: Category[]): number {
  if (!parentId) return 0
  const parent = cats.find(c => c.id === parentId)
  return parent ? parent.level + 1 : 0
}
```

